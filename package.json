{
  "name": "git-groups",
  "displayName": "Git Groups",
  "description": "Group your changed files and commit them separately",
  "version": "0.1.0",
  "publisher": "joo00206",
  "repository": {
    "type": "git",
    "url": "https://github.com/bhin-dede/git-groups"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "SCM Providers"
  ],
  "activationEvents": [
    "*"
  ],
  "icon": "icon.png",
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gitGroupCommit.createGroup",
        "title": "Create Group",
        "icon": "$(add)",
        "category": "Git Groups"
      },
      {
        "command": "gitGroupCommit.deleteGroup",
        "title": "Delete Group",
        "icon": "$(trash)",
        "category": "Git Groups"
      },
      {
        "command": "gitGroupCommit.renameGroup",
        "title": "Rename Group",
        "icon": "$(edit)",
        "category": "Git Groups"
      },
      {
        "command": "gitGroupCommit.addToGroup",
        "title": "Add to Group...",
        "icon": "$(file-add)",
        "category": "Git Groups"
      },
      {
        "command": "gitGroupCommit.removeFromGroup",
        "title": "Remove from Group",
        "icon": "$(remove)",
        "category": "Git Groups"
      },
      {
        "command": "gitGroupCommit.stageGroup",
        "title": "Stage Group",
        "icon": "$(arrow-up)",
        "category": "Git Groups"
      },
      {
        "command": "gitGroupCommit.commitGroup",
        "title": "Commit Group",
        "icon": "$(check)",
        "category": "Git Groups"
      },
      {
        "command": "gitGroupCommit.commitStaged",
        "title": "Commit Staged",
        "icon": "$(check)",
        "category": "Git Groups"
      },
      {
        "command": "gitGroupCommit.toggleCollapse",
        "title": "Toggle Collapse/Expand All",
        "icon": "$(collapse-all)",
        "category": "Git Groups"
      },
      {
        "command": "gitGroupCommit.refresh",
        "title": "Refresh",
        "icon": "$(refresh)",
        "category": "Git Groups"
      },
      {
        "command": "gitGroupCommit.openFile",
        "title": "Open File",
        "icon": "$(go-to-file)",
        "category": "Git Groups"
      },
      {
        "command": "gitGroupCommit.openDiff",
        "title": "Open Changes",
        "icon": "$(diff)",
        "category": "Git Groups"
      },
      {
        "command": "gitGroupCommit.unstageGroup",
        "title": "Move to Changes",
        "icon": "$(arrow-down)",
        "category": "Git Groups"
      },
      {
        "command": "gitGroupCommit.discardGroup",
        "title": "Discard Changes",
        "icon": "$(discard)",
        "category": "Git Groups"
      },
      {
        "command": "gitGroupCommit.unstageFile",
        "title": "Unstage",
        "icon": "$(arrow-down)",
        "category": "Git Groups"
      },
      {
        "command": "gitGroupCommit.stageFile",
        "title": "Stage",
        "icon": "$(arrow-up)",
        "category": "Git Groups"
      },
      {
        "command": "gitGroupCommit.discardFile",
        "title": "Discard Changes",
        "icon": "$(discard)",
        "category": "Git Groups"
      }
    ],
    "viewsContainers": {},
    "views": {
      "scm": [
        {
          "id": "gitGroups",
          "name": "Git Groups",
          "visibility": "visible"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "gitGroupCommit.toggleCollapse",
          "when": "view == gitGroups",
          "group": "navigation"
        },
        {
          "command": "gitGroupCommit.refresh",
          "when": "view == gitGroups",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "gitGroupCommit.commitStaged",
          "when": "view == gitGroups && viewItem == stagedSection",
          "group": "inline"
        },
        {
          "command": "gitGroupCommit.createGroup",
          "when": "view == gitGroups && viewItem == changesSection",
          "group": "inline"
        },
        {
          "command": "gitGroupCommit.commitGroup",
          "when": "view == gitGroups && viewItem == stagedGroup",
          "group": "inline@1"
        },
        {
          "command": "gitGroupCommit.unstageGroup",
          "when": "view == gitGroups && viewItem == stagedGroup",
          "group": "inline@2"
        },
        {
          "command": "gitGroupCommit.stageGroup",
          "when": "view == gitGroups && viewItem == changesGroup",
          "group": "inline@1"
        },
        {
          "command": "gitGroupCommit.discardGroup",
          "when": "view == gitGroups && viewItem == changesGroup",
          "group": "inline@2"
        },
        {
          "command": "gitGroupCommit.deleteGroup",
          "when": "view == gitGroups && viewItem =~ /Group$/",
          "group": "inline@3"
        },
        {
          "command": "gitGroupCommit.renameGroup",
          "when": "view == gitGroups && viewItem =~ /Group$/",
          "group": "1_modify"
        },
        {
          "command": "gitGroupCommit.deleteGroup",
          "when": "view == gitGroups && viewItem =~ /Group$/",
          "group": "2_delete"
        },
        {
          "command": "gitGroupCommit.unstageFile",
          "when": "view == gitGroups && viewItem == stagedFile",
          "group": "inline@1"
        },
        {
          "command": "gitGroupCommit.stageFile",
          "when": "view == gitGroups && viewItem =~ /^(ungroupedFile|groupedFile)$/",
          "group": "inline@1"
        },
        {
          "command": "gitGroupCommit.discardFile",
          "when": "view == gitGroups && viewItem =~ /^(ungroupedFile|groupedFile)$/",
          "group": "inline@2"
        },
        {
          "command": "gitGroupCommit.addToGroup",
          "when": "view == gitGroups && viewItem == ungroupedFile",
          "group": "1_group"
        },
        {
          "command": "gitGroupCommit.removeFromGroup",
          "when": "view == gitGroups && viewItem == groupedFile",
          "group": "1_group"
        }
      ]
    },
    "keybindings": [
      {
        "command": "gitGroupCommit.renameGroup",
        "key": "f2",
        "when": "focusedView == gitGroups"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
